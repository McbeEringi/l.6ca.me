{
	"$schema":"node_modules/wrangler/config-schema.json",
	"name":"l-6ca-me",
	"compatibility_date":"2025-07-15",
		"build":{
		"command":"bun build.mjs",
		"watch_dir":["src","build.mjs","links.mjs"]
	},
	"routes": [
		{"pattern":"l.6ca.me","custom_domain":true}
	],
	"assets":{
		"directory":"./dst",
		"not_found_handling":"404-page"
	}
}
